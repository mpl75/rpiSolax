url=http://192.168.1.100
sn=ABCDEFGH
peak1=5000
peak2=5000
maxPower=10000
maxLoad=16000
delay=4
# Rezerva baterie (min. SoC %), ke které BMS vybíjí – pro odhad „do vybití" ve webu
batteryMinSoC=15

# --- Logování (přidáno) ---
# log=1 zapne ukládání do CSV. Na Macu nech 0, na Raspberry nastav 1.
log=0
# Kam ukládat logy (výchozí: <složka skriptu>/logs). Na Pi typicky:
#logdir=/var/www/html/rpiSolax/logs
